{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "crimson-desert-macos-mod-manager",
  "version": "0.1.0",
  "identifier": "me.mrgigi.crimson-desert-macos-mod-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Crimson Desert Mod Manager",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
