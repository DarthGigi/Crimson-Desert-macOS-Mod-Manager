{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crimson Desert Mod Manager",
  "version": "0.1.2",
  "identifier": "me.mrgigi.crimson-desert-macos-mod-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Crimson Desert Mod Manager",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A macOS mod manager for Crimson Desert.",
    "longDescription": "A macOS-native mod manager for Crimson Desert with support for JSON patch mods, precompiled overlays, browser/raw mods, archive imports, PATHC workflows, recovery tools, and advanced extraction utilities.",
    "resources": [
      "binaries/7z"
    ],
    "macOS": {
      "minimumSystemVersion": "15.0",
      "signingIdentity": "-",
      "dmg": {
        "background": "./icons/background.jpg",
        "windowSize": {
          "width": 960,
          "height": 540
        },
        "appPosition": {
          "x": 260,
          "y": 270
        },
        "applicationFolderPosition": {
          "x": 700,
          "y": 270
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxQTE3QkQ4NzU5QjYyM0UKUldRK1lwdDEySHVoNFl3TEFjQlBPMWZtZ1VJcGorb1NYdC9uWHM4NnNORUQrZUM1bk1qWGQ1d3QK",
      "endpoints": [
        "https://github.com/DarthGigi/Crimson-Desert-macOS-Mod-Manager/releases/latest/download/latest.json"
      ]
    }
  }
}
