{
	"name": "crimson-desert-macos-mod-manager",
	"version": "0.1.3",
	"description": "A macOS mod manager for Crimson Desert with JSON, overlay, PATHC, and archive workflows.",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/DarthGigi/Crimson-Desert-macOS-Mod-Manager.git"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"changeset": "changeset",
		"changeset:status": "changeset status",
		"version-packages": "changeset version && node ./scripts/sync-version.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"tauri": "node ./scripts/tauri-wrapper.mjs",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"prepare": "svelte-kit sync || echo ''"
	},
	"license": "MIT",
	"dependencies": {
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-dialog": "^2.7.0",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-updater": "^2.10.1"
	},
	"devDependencies": {
		"@changesets/changelog-git": "^0.2.1",
		"@changesets/cli": "^2.31.0",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/adapter-static": "latest",
		"@sveltejs/kit": "latest",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@svitejs/changesets-changelog-github-compact": "^1.2.0",
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/cli": "^2.10.1",
		"@types/node": "^25.6.0",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.8"
	}
}
